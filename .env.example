# Runtime profile
ENVIRONMENT=dev
DEPLOYMENT_PROFILE=local
APP_NAME=Job Application Assistant
APP_VERSION=1.1.0
APP_BASE_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000

# Network
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8000

# Storage
APP_DATA_DIR=data
LOG_DIR=logs
APP_DB_PATH=data/job_assistant.sqlite3
LOG_LEVEL=INFO
LOG_FILE=
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Scheduler / automation
SCHEDULER_ENABLED=true

# Free local SQLite-backed API safety limits. Keep enabled for demos.
RATE_LIMITS_ENABLED=true
RATE_LIMIT_BACKEND=sqlite
REDIS_URL=
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_AI_PER_HOUR=60
RATE_LIMIT_FEEDBACK_PER_HOUR=20
RATE_LIMIT_PUBLISH_PER_HOUR=20

# Free local observability. /api/v1/metrics exposes Prometheus-style text.
OBSERVABILITY_ENABLED=true
TRACING_ENABLED=true
METRICS_RETENTION_DAYS=14
ERROR_ALERT_THRESHOLD_PER_HOUR=10
LATENCY_ALERT_THRESHOLD_MS=3000

# Durable local worker queue. SQLite is the demo default.
WORKER_BACKEND=sqlite
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_MAX_ATTEMPTS=3

# Publishing safety defaults. Dry run avoids public posting in demos.
PUBLISHING_REQUIRE_APPROVAL=true
PUBLISHING_DRY_RUN=true

# Compliance retention defaults.
AUDIT_RETENTION_DAYS=365
EXPORT_RETENTION_DAYS=7

# User-owned provider API keys are saved encrypted per user in the database from the Integrations page.
# Do not put user-owned OpenAI/Claude/Gemini/RapidAPI/Apify/LinkedIn keys in .env.
DEFAULT_AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# Required for staging/production. Generate with: python scripts/generate_secrets.py
APP_ENCRYPTION_KEY=
JWT_SECRET_KEY=change-me-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
SESSION_COOKIE_SECURE=false

# Optional Gmail API OAuth files / settings. See README for setup.
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=job-assistant

# PostgreSQL support placeholder. SQLite remains default for demos.
# DATABASE_URL=postgresql+psycopg2://user:password@postgres:5432/job_assistant
