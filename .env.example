# Required only for AI extraction/scoring/generation. App works with local fallback when absent.
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-5.5

# Optional Gmail API OAuth files. See README for setup.
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# Local database path
APP_DB_PATH=data/job_assistant.sqlite3
