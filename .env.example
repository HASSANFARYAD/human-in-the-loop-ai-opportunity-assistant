# Required only for AI extraction/scoring/generation. App works with local fallback when absent.
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-5.5

# Optional Gmail API OAuth files. See README for setup.
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# Local database path
APP_DB_PATH=data/job_assistant.sqlite3

# Required in production. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
SESSION_COOKIE_SECURE=false
DEFAULT_AI_PROVIDER=openai

# Multi-user Google OAuth / Gmail
APP_BASE_URL=http://localhost:8501
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=job-assistant
